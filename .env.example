# Renombra este archivo a .env si quieres centralizar todo,
# o crea los siguientes archivos separados:
# GROQ_API_KEY.env
# HF_API_KEY.env

GROQ_API_KEY=tu_clave_de_groq_aqui
HF_API_KEY=tu_clave_de_hugging_face_aqui

# Opcional: lista de modelos Groq separados por coma.
# Si el primero falla, TrendRadar prueba el siguiente.
GROQ_MODELS=llama-3.3-70b-versatile,llama3-70b-8192
